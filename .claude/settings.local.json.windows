{
  "hooks": {
    "PreToolUse": [{
      "matcher": "Bash",
      "hooks": [{
        "type": "command",
        "command": "uv run \"%USERPROFILE%\\.claude\\hooks\\guard.py\""
      }]
    }, {
      "matcher": "Edit|Write|MultiEdit",
      "hooks": [{
        "type": "command",
        "command": "uv run \"%USERPROFILE%\\.claude\\hooks\\guard.py\""
      }]
    }, {
      "matcher": "Read",
      "hooks": [{
        "type": "command",
        "command": "uv run \"%USERPROFILE%\\.claude\\hooks\\guard.py\""
      }]
    }],
    "Stop": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "uv run \"%USERPROFILE%\\.claude\\hooks\\notification.py\" --notify"
      }]
    }],
    "Notification": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "uv run \"%USERPROFILE%\\.claude\\hooks\\notification.py\" --permission"
      }]
    }]
  },
  "permissions": {
    "allow": [],
    "deny": [],
    "ask": []
  },
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "uv run \"%USERPROFILE%\\.claude\\hooks\\statusline.py\"",
    "padding": 0
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
