{
  "hooks": {
    "PreToolUse": [{
      "matcher": "Bash",
      "hooks": [{
        "type": "command",
        "command": "uv run .claude\\hooks\\guard.py"
      }]
    }, {
      "matcher": "Edit|Write|MultiEdit",
      "hooks": [{
        "type": "command",
        "command": "uv run .claude\\hooks\\guard.py"
      }]
    }],
    "Stop": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "uv run .claude\\hooks\\notification.py --notify"
      }]
    }],
    "Notification": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
        "command": "uv run .claude\\hooks\\notification.py --permission"
      }]
    }]
  },
  "permissions": {
    "allow": [],
    "deny": [],
    "ask": []
  },
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "uv run .claude\\hooks\\statusline.py",
    "padding": 0
  },
  "env": {
    "CONTEXT7_API_KEY": "paste_your_token",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "TTS_LANGUAGE": "en",
    "DESKTOP_NOTIFICATIONS": "true"
  }
}
