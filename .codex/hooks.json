{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|shell",
        "hooks": [{
          "type": "command",
          "command": "python3 ~/.codex/hooks/guard.py"
        }]
      },
      {
        "matcher": "Edit|Write|MultiEdit|file_edit|file_write",
        "hooks": [{
          "type": "command",
          "command": "python3 ~/.codex/hooks/guard.py"
        }]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [{
          "type": "command",
          "command": "python3 ~/.codex/hooks/notification.py --notify"
        }]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [{
          "type": "command",
          "command": "python3 ~/.codex/hooks/notification.py --permission"
        }]
      }
    ]
  }
}
